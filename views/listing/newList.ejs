<%- layout("/Layouts/boilerplate") %>

<div class="row offset-2">
    <div class="col-9">
        <h3 class="mt-2 mb-3">Create New List</h3>
   <form method="post">
  <div class="mb-3">
    <label for="Title" class="form-label">Title:</label>
    <input type="text" class="form-control" id="Title" placeholder="Enter Title">
  </div>
  <div class="mb-3">
    <label class="form-check-label" for="description">Description</label>
    <input type="text" class="form-control" id="description"placeholder="Enter Description">
  </div>
  <div class="mb-3">
    <label for="image" class="form-label">Image:</label>
    <input type="password" class="form-control" id="image">
  </div>
 
<div class="row">
     <div class="col-lg mb-3">
        <label for="price" class="form-label">Price:</label>
        <input type="password" class="form-control" id="price" placeholder="1200rs">
    </div>
    <div class="col-lg mb-3">
        <label for="country" class="form-label">Country:</label>
        <input type="password" class="form-control" id="country" placeholder="Enter Country">
    </div>
</div>

  <div class="mt-3">
    <label for="location" class="form-label">Location:</label>
    <input type="password" class="form-control" id="location" placeholder="Enter Location">
  </div>
  <button type="submit" class="btn btn-outline-success mt-3 mb-3">Submit</button>
</form>
</div>
</div>